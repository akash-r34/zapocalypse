*.tsbuildinfo
next-env.d.ts

# Obsidian per-machine UI state (keep community-plugins.json + core-plugins.json tracked)
Obsidian Vault/Zapocalypse/.obsidian/workspace.json
Obsidian Vault/Zapocalypse/.obsidian/workspace-mobile.json
